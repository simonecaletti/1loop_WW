Cell[CellGroupData[{

Cell["Numerical implementation of the four vectors", "Section",
 CellChangeTimes->{{3.983522197179412*^9, 
  3.983522213307777*^9}},ExpressionUUID->"41564be8-4844-457f-b3ac-\
562c0de4453a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"RandomLorentzVector", "[", "m2_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"p3", ",", "p2", ",", "E"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Random", " ", "spatial", " ", "vector", " ", "with", " ", 
      "components", " ", 
      RowBox[{"in", "[", 
       RowBox[{
        RowBox[{"-", "5"}], ",", "5"}], "]"}]}], "*)"}], 
    RowBox[{
     RowBox[{"p3", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", "3"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"p2", "=", 
      RowBox[{"p3", ".", "p3"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "2.", " ", "Adjust", " ", "if", " ", "necessary", " ", "so", " ", 
          RowBox[{"E", "^", "2"}]}], "-"}], " ", "|", "p", "|", 
        RowBox[{"^", "2"}]}], "=", "m2"}], "*)"}], 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"p2", "+", "m2"}], "<", "0"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "If", " ", "argument", " ", "of", " ", "sqrt", " ", "is", " ", 
          "negative"}], ",", 
         RowBox[{"rescale", " ", "spatial", " ", "part", " ", "down"}]}], 
        "*)"}], 
       RowBox[{
        RowBox[{"p3", "*=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"Abs", "[", "m2", "]"}], "]"}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"p2", "+", 
            RowBox[{"Abs", "[", "m2", "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"p2", "=", 
         RowBox[{"p3", ".", "p3"}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"E", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"p2", "+", "m2"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"E", ",", 
       RowBox[{"Sequence", "@@", "p3"}]}], "}"}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"LightlikePair", "[", "P_", "]"}], " ", ":=", " ", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "E", ",", "p", ",", "n", ",", "k1", ",", "k2", ",", "\[Alpha]", ",", 
      "disc"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"E", ",", "p"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"P", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", 
        RowBox[{"P", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", "4"}], "]"}], "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"E", "^", "2"}], "-", 
         RowBox[{"p", ".", "p"}]}], "<=", "0"}], ",", 
       RowBox[{"Return", "[", "\"\<P must be timelike\>\"", "]"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "1.", " ", "pick", " ", "a", " ", "random", " ", "spatial", " ", 
       "direction", " ", "for", " ", "k1"}], "*)"}], 
     RowBox[{"n", "=", 
      RowBox[{"Normalize", "[", 
       RowBox[{"RandomReal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "3"}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"2.", " ", "write", " ", "k1"}], "=", 
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"(", 
          RowBox[{"1", ",", "k1dir"}], ")"}]}]}], ",", 
       RowBox[{"k2", "=", 
        RowBox[{"P", "-", "k1"}]}]}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"3.", " ", "impose", " ", 
        RowBox[{"k2", "^", "2"}]}], "=", 
       RowBox[{"0", "->", 
        RowBox[{"quadratic", " ", "for", " ", "\[Alpha]"}]}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"E", "^", "2"}], "-", 
         RowBox[{"p", ".", "p"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"E", "-", 
           RowBox[{"p", ".", "n"}]}], ")"}]}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"k1", "=", 
      RowBox[{"\[Alpha]", " ", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Sequence", "@@", "n"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"k2", "=", 
      RowBox[{"P", "-", "k1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"k1", ",", "k2"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"m3", " ", "=", " ", "2"}], " ", ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "Note", " ", "that", " ", "is", " ", "the", " ", "mass", " ", "squared"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m4", "=", " ", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p3", " ", "=", " ", 
   RowBox[{"RandomLorentzVector", "[", "m3", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p4", "=", " ", 
   RowBox[{"RandomLorentzVector", "[", "m4", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p1", ",", "p2"}], "}"}], " ", "=", " ", 
   RowBox[{"LightlikePair", "[", 
    RowBox[{
     RowBox[{"-", "p3"}], "-", "p4"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p5", ",", "p6"}], "}"}], " ", "=", " ", 
   RowBox[{"LightlikePair", "[", "p3", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p7", ",", "p8"}], "}"}], " ", "=", " ", 
   RowBox[{"LightlikePair", "[", "p4", "]"}]}], ";"}]}], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"ec38bb98-520f-4602-8d0d-9c99d467eac2"],

